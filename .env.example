# --- Database (Neon / PostgreSQL) ---
DB_HOST=your-host.neon.tech
DB_NAME=AkademVault
DB_USER=neondb_owner
DB_PASSWORD=replace_me
DB_SSLMODE=require
DB_CHANNELBINDING=require
DB_PORT=5432
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=akademvault

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
# Shared default model. Used by both workloads unless overridden below.
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
# Per-workload overrides (optional). The schedule parser needs VISION (image/PDF) and
# accuracy — only set it to a model that accepts image input. The digest is text-only
# and non-critical. Leave a line unset to fall back to OPENROUTER_MODEL.
#   List live free models:
#   curl -s https://openrouter.ai/api/v1/models | grep -o '"id":"[^"]*:free"' | sort -u
# OPENROUTER_MODEL_PARSER=<vision-capable model id>
# OPENROUTER_MODEL_DIGEST=<text model id>
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- URLs ---
# Публічний URL цього API.
APP_BASE_URL=http://localhost:5259
# Кома-розділений список дозволених origin-ів для CORS.
# Веб-фронтенд:   https://app.example.com
# Capacitor iOS:  capacitor://localhost
# Capacitor And.: http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:4200,capacitor://localhost,http://localhost
