# --- Database (Neon / PostgreSQL) ---
DB_HOST=your-host.neon.tech
DB_NAME=AkademVault
DB_USER=neondb_owner
DB_PASSWORD=replace_me
DB_SSLMODE=require
DB_CHANNELBINDING=require
DB_PORT=5432
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=akademvault

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
# Shared default model. Used by a workload whose own pool is unset.
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
#
# Per-workload model POOLS (comma-separated, tried in order, fall through on
# rate-limit / out-of-credit / error / empty reply). Lets a free-tier key stay up
# across several models' separate daily limits; a paid model can sit last as a
# guaranteed backstop.
#
# PARSER pool — schedule parsing. Needs VISION (image/PDF) AND accuracy, so list
# ONLY image-capable models, and keep the paid model last as a safety net. Verify
# which free models accept images before relying on them:
#   curl -s https://openrouter.ai/api/v1/models | python3 -c "import sys,json;
#   [print(m['id']) for m in json.load(sys.stdin)['data']
#    if m['id'].endswith(':free') and 'image' in m.get('architecture',{}).get('input_modalities',[])]"
# OPENROUTER_MODEL_PARSER=moonshotai/kimi-k2.6:free,google/gemma-4-31b-it:free,anthropic/claude-haiku-4-5
#
# DIGEST pool — text only, non-critical, all free is fine.
# OPENROUTER_MODEL_DIGEST=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free
#
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Gemini (optional, schedule parser only) ---
# Google AI Studio has its own free tier that INCLUDES vision, billed separately from
# OpenRouter — handy when the OpenRouter balance can't cover inlining a schedule image.
# Set GEMINI_API_KEY and the parser uses Gemini directly; leave it unset and the parser
# falls back to the OpenRouter vision pool above. The digest always stays on OpenRouter.
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# --- URLs ---
# Публічний URL цього API.
APP_BASE_URL=http://localhost:5259
# Кома-розділений список дозволених origin-ів для CORS.
# Веб-фронтенд:   https://app.example.com
# Capacitor iOS:  capacitor://localhost
# Capacitor And.: http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:4200,capacitor://localhost,http://localhost
